# .gitignore for SPENCE

# Database files - Never commit personal data
database/spence.db
database/spence.db-shm
database/spence.db-wal
database/*.backup
database/*.db

# Keep the schema and empty database
!database/schema.sql
!database/spence_empty.db

# API Keys and local config
core/credentials.env
core/openrouter.env
core/keys.json
.env

# Uploaded images and ingest cache
ingest/
uploads/
cache/

# Generated logs and temp artifacts
core/*.log
core/*.base64

# System / IDE
.DS_Store
.vscode/
node_modules/
